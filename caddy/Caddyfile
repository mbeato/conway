            header_up X-Real-IP {remote_host}
            header_up -X-Forwarded-For
        }
    }

    @auth_paths path /auth/* /signup /login /verify /forgot-password /account /account/* /billing/*
    handle @auth_paths {
        import staging_dashboard_headers
        header Cache-Control "no-store"
        reverse_proxy localhost:3010 {
            header_up X-Real-IP {remote_host}
            header_up -X-Forwarded-For
