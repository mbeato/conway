# Import per-service configs (e.g. Tonos) that live outside this file
import /etc/caddy/conf.d/*.caddyfile

(security_headers) {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Content-Security-Policy "default-src 'none'; frame-ancestors 'none'"
        Permissions-Policy "geolocation=(), camera=(), microphone=()"
        -Server
    }
}

(dashboard_headers) {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'"
        Permissions-Policy "geolocation=(), camera=(), microphone=()"
        -Server
    }
}

# Wedge sub-apps (agentsmd, stripesig) serve full landing.html with inline
# <style> + <script> and pull Instrument Serif / DM Sans / JetBrains Mono
# from Google Fonts (added in the apimesh-brand rebrand). The wildcard
# *.apimesh.xyz block's default-src 'none' would strip styles and block the
# fonts; this snippet allows inline + the two fonts.googleapis/gstatic origins.
(wedge_headers) {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'"
        Permissions-Policy "geolocation=(), camera=(), microphone=()"
        -Server
    }
}

apimesh.xyz {
    request_body {
        max_size 64KB
    }

    handle /.well-known/* {
        root * /opt/conway-agent/public
        file_server
    }

    handle /llms.txt {
        root * /opt/conway-agent/public
        file_server
    }

    handle /llms-full.txt {
        root * /opt/conway-agent/public
        file_server
    }

    handle /logo*.svg {
        root * /opt/conway-agent/public
        file_server
    }

    # apex root → static wedge index (public/hub.html).
    # The hub is a thin discovery surface that lists live wedges. It is
    # intentionally distinct from mbeato.dev/work/apimesh (the case study /
    # narrative — for people evaluating max). The hub is for people
    # evaluating the tools themselves. Served straight from caddy with no
    # bun hop so it stays fast.
    @landing path /
    handle @landing {
        root * /opt/conway-agent/public
        rewrite * /hub.html
        file_server
        header Content-Type "text/html; charset=utf-8"
        header Cache-Control "public, max-age=300"
    }

    handle /dashboard {
        import dashboard_headers
        reverse_proxy localhost:3000 {
            header_up X-Real-IP {remote_host}
            header_up -X-Forwarded-For
        }
    }

    # Stripe webhook — no CSP, no cache headers
    handle /billing/webhook {
        reverse_proxy localhost:3000 {
            header_up X-Real-IP {remote_host}
            header_up -X-Forwarded-For
        }
    }

    # Auth, account, and billing pages — no caching of sensitive content
    @auth_paths path /auth/* /signup /login /verify /forgot-password /account /account/* /billing/*
    handle @auth_paths {
        import dashboard_headers
        header Cache-Control "no-store"
        reverse_proxy localhost:3000 {
            header_up X-Real-IP {remote_host}
            header_up -X-Forwarded-For
        }
    }

    handle {
        import security_headers
        reverse_proxy localhost:3000 {
            header_up X-Real-IP {remote_host}
            header_up -X-Forwarded-For
        }
    }
}

mcp.apimesh.xyz {
    import security_headers

    tls {
        dns cloudflare {env.CF_API_TOKEN}
    }

    request_body {
        max_size 64KB
    }
    reverse_proxy localhost:3002 {
        header_up X-Real-IP {remote_host}
        header_up -X-Forwarded-For
    }
}

# Wedge subdomains — must come BEFORE *.apimesh.xyz so Caddy's most-specific
# match wins and we get the relaxed wedge_headers CSP instead of the wildcard's
# default-src 'none' (which breaks inline styles + scripts in landing.html).
agentsmd.apimesh.xyz, stripesig.apimesh.xyz {
    import wedge_headers

    tls {
        dns cloudflare {env.CF_API_TOKEN}
    }

    request_body {
        max_size 16KB
    }

    # Brand assets — served from the same /opt/conway-agent/public dir the
    # apex uses, so the wedge nav <img> renders instead of 404'ing.
    handle /logo*.svg {
        root * /opt/conway-agent/public
        file_server
    }

    reverse_proxy localhost:3001 {
        header_up X-Real-IP {remote_host}
        header_up -X-Forwarded-For
        header_up -X-APIMesh-Internal
        header_up -X-APIMesh-User-Id
        header_up -X-APIMesh-Key-Id
        header_up -X-APIMesh-Paid
    }
}

*.apimesh.xyz {
    import security_headers

    tls {
        dns cloudflare {env.CF_API_TOKEN}
    }

    request_body {
        max_size 16KB
    }
    # Authorization header passes through automatically (API key auth)
    reverse_proxy localhost:3001 {
        header_up X-Real-IP {remote_host}
        header_up -X-Forwarded-For
        header_up -X-APIMesh-Internal
        header_up -X-APIMesh-User-Id
        header_up -X-APIMesh-Key-Id
        header_up -X-APIMesh-Paid
    }
}

# --- Staging environment ---
# Shorter HSTS, no preload — staging is not production

(staging_security_headers) {
    header {
        Strict-Transport-Security "max-age=3600; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Content-Security-Policy "default-src 'none'; frame-ancestors 'none'"
        Permissions-Policy "geolocation=(), camera=(), microphone=()"
        -Server
    }
}

(staging_dashboard_headers) {
    header {
        Strict-Transport-Security "max-age=3600; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'"
        Permissions-Policy "geolocation=(), camera=(), microphone=()"
        -Server
    }
}

